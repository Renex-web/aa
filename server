// ==================== PROMOTION_VEHICLE (Linking) ====================
app.get('/api/promotion-vehicles', requireAuth, async (req, res) => {
  const links = await PromotionVehicle.find()
    .populate('promotion')
    .populate('vehicle');
  res.json(links);
});

app.post('/api/promotion-vehicles', requireAuth, async (req, res) => {
  try {
    const { promotionId, vehicleId, performance } = req.body;
    const existing = await PromotionVehicle.findOne({ promotion: promotionId, vehicle: vehicleId });
    if (existing) return res.status(400).json({ message: 'This vehicle is already linked to this promotion' });

    const link = await PromotionVehicle.create({
      promotion: promotionId,
      vehicle: vehicleId,
      performance: performance || 'Scheduled'
    });
    res.status(201).json(await link.populate(['promotion', 'vehicle']));
  } catch (error) {
    sendError(res, error, 'Could not link promotion to vehicle');
  }
});

app.delete('/api/promotion-vehicles/:promotionId/:vehicleId', requireAuth, async (req, res) => {
  await PromotionVehicle.findOneAndDelete({
    promotion: req.params.promotionId,
    vehicle: req.params.vehicleId
  });
  res.json({ message: 'Link removed' });
});

// ==================== REPORT - Customers & Promotions ====================
app.get('/api/customer-promotion-report', requireAuth, async (req, res) => {
  try {
    const customers = await Customer.find({ status: 'Active' });
    const vehicles = await Vehicle.find({ status: 'Available' });
    const promotions = await Promotion.find({ status: 'Active', startDate: { $lte: new Date() }, endDate: { $gte: new Date() } });
    const links = await PromotionVehicle.find().populate('promotion').populate('vehicle');

    const report = [];

    for (const customer of customers) {
      for (const vehicle of vehicles.slice(0, 3)) {
        const matchingLinks = links.filter(link =>
          link.vehicle._id.toString() === vehicle._id.toString() &&
          link.promotion.status === 'Active'
        );

        for (const link of matchingLinks) {
          report.push({
            customerName: `${customer.firstName} ${customer.lastName}`,
            vehicleBrand: vehicle.brand,
            vehicleModel: vehicle.model,
            promotionTitle: link.promotion.title,
            discountValue: link.promotion.discountType === 'percentage'
              ? `${link.promotion.discountValue}%`
              : link.promotion.discountType === 'amount'
              ? `${link.promotion.discountValue} RWF`
              : link.promotion.discountType,
            performance: link.performance
          });
        }
      }
    }

    res.json(report);
  } catch (error) {
    sendError(res, error, 'Could not generate report');
  }
});

// ==================== DASHBOARD SUMMARY ====================
app.get('/api/dashboard', requireAuth, async (req, res) => {
  const [vehicles, customers, promotions, activePromotions, links] = await Promise.all([
    Vehicle.countDocuments(),
    Customer.countDocuments(),
    Promotion.countDocuments(),
    Promotion.countDocuments({ status: 'Active', startDate: { $lte: new Date() }, endDate: { $gte: new Date() } }),
    PromotionVehicle.countDocuments()
  ]);

  res.json({
    summary: {
      vehicles,
      customers,
      promotions,
      activePromotions,
      promotionLinks: links
    }
  });
});

